# Git Ignore para Sistema REM PHP

# Archivos de configuración sensibles
.env
.env.*
!.env.example
config/.env.local.php

# Directorio de uploads
uploads/*
!uploads/.gitkeep

# Logs
*.log
logs/

# Sistema operativo
.DS_Store
Thumbs.db
desktop.ini

# IDEs
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# Dependencias de Composer (si se usa en el futuro)
/vendor/

# Dependencias Node / artefactos generados
/node_modules/
/assets/libs/*/coverage/

# Archivos temporales
*.tmp
*.temp
*.cache

# Archivos de sesión PHP
/tmp/

# Archivos de backup
*.bak
*.backup
*~

# Scripts con credenciales (no commitear)
run_migrations.php
